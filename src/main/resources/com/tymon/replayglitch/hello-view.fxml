<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>

<GridPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="250.0" minWidth="400.0"
          prefHeight="400.0" prefWidth="600.0"
          xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.tymon.replayglitch.HelloController">

   <columnConstraints>
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="50.0" prefWidth="100.0" />
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="50.0" prefWidth="100.0" />
   </columnConstraints>

   <rowConstraints>
      <RowConstraints minHeight="10.0" percentHeight="20.0" prefHeight="30.0" vgrow="SOMETIMES" />
      <RowConstraints minHeight="10.0" percentHeight="50.0" prefHeight="30.0" vgrow="SOMETIMES" />
      <RowConstraints minHeight="10.0" percentHeight="30.0" prefHeight="30.0" vgrow="SOMETIMES" />
   </rowConstraints>

   <children>
      <!-- Force the label to align to the absolute top-left of its grid block, padded by 10px -->
      <Label fx:id="statusLabel" text="Inactive"
             GridPane.columnIndex="0" GridPane.rowIndex="0"
             GridPane.halignment="LEFT" GridPane.valignment="TOP">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
         <GridPane.margin>
            <Insets left="10.0" top="10.0" />
         </GridPane.margin>
      </Label>

      <!-- Activate Button -->
      <Button mnemonicParsing="false" onAction="#onActionOneClick" prefHeight="40.0" prefWidth="140.0"
              text="Activate" GridPane.columnIndex="0" GridPane.halignment="CENTER" GridPane.rowIndex="2" GridPane.valignment="CENTER" />

      <!-- Deactivate Button -->
      <Button mnemonicParsing="false" onAction="#onActionTwoClick" prefHeight="40.0" prefWidth="140.0"
              text="Deactivate" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="2" GridPane.valignment="CENTER" />
   </children>
</GridPane>